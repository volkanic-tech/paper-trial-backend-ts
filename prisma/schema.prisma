// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  firstName  String
  lastName   String
  address    String
  phone      String   @unique
  email      String   @unique
  password   String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  isInternal Boolean  @default(false)
  orders     Order[]
}

model Admin {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  phone     String    @unique
  address   String
  password  String
  lastLogin DateTime?
  role      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
}

model Category {
  id                    Int                   @id @default(autoincrement())
  name                  String                @unique
  isActive              Boolean               @default(true)
  isSubCategory         Boolean               @default(false)
  createdAt             DateTime              @default(now())
  products              Product[]
  categorySubCategories CategorySubCategory[] @relation("CategoryToSubCategories")
  subCategoryCategories CategorySubCategory[] @relation("SubCategoryToCategories")
}

model CategorySubCategory {
  id            Int      @id @default(autoincrement())
  categoryId    Int
  subCategoryId Int
  category      Category @relation("CategoryToSubCategories", fields: [categoryId], references: [id], onDelete: Cascade)
  subCategory   Category @relation("SubCategoryToCategories", fields: [subCategoryId], references: [id], onDelete: Cascade)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([categoryId, subCategoryId])
}

model Product {
  id             Int            @id @default(autoincrement())
  sku            String         @unique
  name           String
  description    String?
  price          Float
  originalPrice  Float
  costPrice      Float
  features       Json
  specifications Json
  categoryId     Int
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  stock          Int
  isActive       Boolean        @default(true)
  isNew          Boolean        @default(true)
  isFeatured     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  images         ProductImage[]
  orderItems     OrderItem[]
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

model QuotationInvoice {
  id              Int      @id @default(autoincrement())
  generatedId     String   @unique
  type            String
  customerId      Int?
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress String?
  issueDate       DateTime
  expiryDate      DateTime
  items           Json
  subtotal        Float
  taxRate         Float
  taxAmount       Float
  shippingFee     Float
  discountRate    Float
  discountAmount  Float
  total           Float
  status          String
  notes           String?
  createdAt       DateTime @default(now())
}

model Order {
  id              Int         @id @default(autoincrement())
  uuid            String      @unique
  userId          Int
  user            User        @relation(fields: [userId], references: [id])
  total           Float
  subtotal        Float
  shippingFee     Float
  tax             Float
  discount        Float?
  status          String
  paymentStatus   String
  paymentMethod   String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  shippingAddress Json
  billingAddress  Json?
  trackingNumber  String?
  notes           String?
  orderItems      OrderItem[]
  payments        PaymentTransaction[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Vendor {
  id      Int    @id @default(autoincrement())
  name    String
  address String
  phone   String @unique
  email   String @unique
}

model PaymentTransaction {
  id                   Int       @id @default(autoincrement())
  orderId              Int
  order                Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider             String
  providerReference    String?
  internalReference    String    @unique
  amount               Float
  currency             String
  status               String
  gatewayStatusCode    String?
  gatewayMessage       String?
  gatewayPaymentMethod String?
  requestPayload       Json?
  responsePayload      Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime?

  @@index([orderId])
  @@index([provider, providerReference])
  @@index([status])
}
